generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model District {
  id             Int             @id @default(autoincrement())
  name           String          @db.VarChar(100)
  code           String          @unique @db.VarChar(10)
  createdAt      DateTime        @default(now()) @map("created_at")
  deletedAt      DateTime?       @map("deleted_at")
  courts         Court[]
  dataEntries    DataEntry[]
  grievances     Grievance[]
  magistrates    Magistrate[]
  policeStations PoliceStation[]
  transfersFrom  TransferLog[]   @relation("TransferFrom")
  transfersTo    TransferLog[]   @relation("TransferTo")
  users          User[]

  @@map("districts")
}

model Court {
  id                 Int           @id @default(autoincrement())
  districtId         Int           @map("district_id")
  name               String        @db.VarChar(150)
  courtNo            String        @map("court_no") @db.VarChar(20)
  magistrateId       Int?          @map("magistrate_id")
  createdAt          DateTime      @default(now()) @map("created_at")
  deletedAt          DateTime?     @map("deleted_at")
  cisNumber          String?       @map("cis_number") @db.VarChar(50)
  district           District      @relation(fields: [districtId], references: [id])
  magistrate         Magistrate?   @relation(fields: [magistrateId], references: [id])
  dataEntries        DataEntry[]
  transfersFromCourt TransferLog[] @relation("TransferFromCourt")
  transfersToCourt   TransferLog[] @relation("TransferToCourt")
  usersLastSelected  User[]        @relation("LastSelectedCourt")
  dailySubmissions   DailySubmission[]

  @@unique([districtId, courtNo])
  @@map("courts")
}

model Magistrate {
  id          Int         @id @default(autoincrement())
  name        String      @db.VarChar(150)
  designation String      @db.VarChar(100)
  districtId  Int?        @map("district_id")
  phone       String?     @db.VarChar(15)
  createdAt   DateTime    @default(now()) @map("created_at")
  deletedAt   DateTime?   @map("deleted_at")
  gender      String?     @db.VarChar(10)
  courts      Court[]
  dataEntries DataEntry[]
  district    District?   @relation(fields: [districtId], references: [id])

  @@unique([districtId, name])
  @@map("magistrates")
}

model User {
  id                  Int                @id @default(autoincrement())
  username            String             @unique @db.VarChar(50)
  password            String             @map("password_hash")
  name                String             @db.VarChar(150)
  role                UserRole
  districtId          Int?               @map("district_id")
  phone               String?            @db.VarChar(15)
  lastSelectedCourtId Int?               @map("last_selected_court_id")
  refreshToken        String?            @map("refresh_token")
  createdAt           DateTime           @default(now()) @map("created_at")
  deletedAt           DateTime?          @map("deleted_at")
  rank                String?            @db.VarChar(50)
  dataEntriesCreated  DataEntry[]        @relation("EntryCreatedBy")
  dataEntriesUpdated  DataEntry[]        @relation("EntryUpdatedBy")
  dataTablesCreated   DataEntryTable[]
  grievanceComments   GrievanceComment[]
  grievancesAssigned  Grievance[]        @relation("GrievanceAssignedTo")
  grievancesRaised    Grievance[]        @relation("GrievanceRaisedBy")
  transfersMade       TransferLog[]      @relation("TransferredBy")
  alerts              Alert[]            @relation("UserAlerts")
  district            District?          @relation(fields: [districtId], references: [id])
  lastSelectedCourt   Court?             @relation("LastSelectedCourt", fields: [lastSelectedCourtId], references: [id])
  dailySubmissions    DailySubmission[]  @relation("SubmissionCreatedBy")

  @@map("users")
}

model TransferLog {
  id                Int                @id @default(autoincrement())
  entityType        TransferEntityType @map("entity_type")
  entityId          Int                @map("entity_id")
  fromDistrictId    Int?               @map("from_district_id")
  toDistrictId      Int?               @map("to_district_id")
  fromCourtId       Int?               @map("from_court_id")
  toCourtId         Int?               @map("to_court_id")
  transferredBy     Int                @map("transferred_by")
  transferDate      DateTime           @map("transfer_date") @db.Date
  createdAt         DateTime           @default(now()) @map("created_at")
  fromCourt         Court?             @relation("TransferFromCourt", fields: [fromCourtId], references: [id])
  fromDistrict      District?          @relation("TransferFrom", fields: [fromDistrictId], references: [id])
  toCourt           Court?             @relation("TransferToCourt", fields: [toCourtId], references: [id])
  toDistrict        District?          @relation("TransferTo", fields: [toDistrictId], references: [id])
  transferredByUser User               @relation("TransferredBy", fields: [transferredBy], references: [id])

  @@map("transfer_logs")
}

model DataEntryTable {
  id          Int               @id @default(autoincrement())
  name        String            @db.VarChar(100)
  slug        String            @unique @db.VarChar(100)
  description String?
  singleRow   Boolean           @default(false) @map("single_row")
  sortOrder   Int               @default(0) @map("sort_order")
  createdBy   Int               @map("created_by")
  createdAt   DateTime          @default(now()) @map("created_at")
  deletedAt   DateTime?         @map("deleted_at")
  entries     DataEntry[]
  columns     DataEntryColumn[]
  creator     User              @relation(fields: [createdBy], references: [id])

  @@map("data_entry_tables")
}

model DataEntryColumn {
  id          Int            @id @default(autoincrement())
  tableId     Int            @map("table_id")
  name        String         @db.VarChar(100)
  slug        String         @db.VarChar(100)
  dataType    ColumnDataType @map("data_type")
  enumOptions Json?          @map("enum_options")
  isRequired  Boolean        @default(true) @map("is_required")
  sortOrder   Int            @default(0) @map("sort_order")
  createdAt   DateTime       @default(now()) @map("created_at")
  deletedAt   DateTime?      @map("deleted_at")
  table       DataEntryTable @relation(fields: [tableId], references: [id])

  @@unique([tableId, slug])
  @@map("data_entry_columns")
}

model DataEntry {
  id            Int            @id @default(autoincrement())
  tableId       Int            @map("table_id")
  districtId    Int            @map("district_id")
  courtId       Int            @map("court_id")
  magistrateId  Int?           @map("magistrate_id")
  entryDate     DateTime       @map("entry_date") @db.Date
  values        Json
  createdBy     Int            @map("created_by")
  updatedBy     Int?           @map("updated_by")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  court         Court          @relation(fields: [courtId], references: [id])
  createdByUser User?          @relation("EntryCreatedBy", fields: [createdBy], references: [id])
  district      District       @relation(fields: [districtId], references: [id])
  magistrate    Magistrate?    @relation(fields: [magistrateId], references: [id])
  table         DataEntryTable @relation(fields: [tableId], references: [id])
  updatedByUser User?          @relation("EntryUpdatedBy", fields: [updatedBy], references: [id])

  @@map("data_entries")
}

model Grievance {
  id             Int                @id @default(autoincrement())
  raisedBy       Int                @map("raised_by")
  subject        String             @db.VarChar(200)
  description    String
  status         GrievanceStatus    @default(open)
  currentLevel   GrievanceLevel     @map("current_level")
  districtId     Int?               @map("district_id")
  assignedTo     Int?               @map("assigned_to")
  createdAt      DateTime           @default(now()) @map("created_at")
  resolvedAt     DateTime?          @map("resolved_at")
  comments       GrievanceComment[]
  attachments    GrievanceAttachment[]
  assignedToUser User?              @relation("GrievanceAssignedTo", fields: [assignedTo], references: [id])
  district       District?          @relation(fields: [districtId], references: [id])
  raisedByUser   User               @relation("GrievanceRaisedBy", fields: [raisedBy], references: [id])

  @@map("grievances")
}

model GrievanceAttachment {
  id          Int       @id @default(autoincrement())
  grievanceId Int       @map("grievance_id")
  commentId   Int?      @map("comment_id")
  fileName    String    @map("file_name") @db.VarChar(255)
  filePath    String    @map("file_path") @db.VarChar(255)
  mimeType    String    @map("mime_type") @db.VarChar(100)
  fileSize    Int       @map("file_size")
  createdAt   DateTime  @default(now()) @map("created_at")
  grievance   Grievance @relation(fields: [grievanceId], references: [id], onDelete: Cascade)
  comment     GrievanceComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@map("grievance_attachments")
}

model GrievanceComment {
  id          Int       @id @default(autoincrement())
  grievanceId Int       @map("grievance_id")
  userId      Int       @map("user_id")
  body        String
  createdAt   DateTime  @default(now()) @map("created_at")
  grievance   Grievance @relation(fields: [grievanceId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
  attachments GrievanceAttachment[]

  @@map("grievance_comments")
}

model Alert {
  id         Int       @id @default(autoincrement())
  districtId Int       @map("district_id")
  userId     Int?      @map("user_id")
  alertType  String    @map("alert_type") @db.VarChar(50)
  message    String
  metadata   Json?
  resolved   Boolean   @default(false)
  resolvedBy Int?      @map("resolved_by")
  alertDate  DateTime  @map("alert_date") @db.Date
  createdAt  DateTime  @default(now()) @map("created_at")
  resolvedAt DateTime? @map("resolved_at")
  user       User?     @relation("UserAlerts", fields: [userId], references: [id])

  @@map("alerts")
}

model PoliceStation {
  id         Int       @id @default(autoincrement())
  districtId Int       @map("district_id")
  name       String    @db.VarChar(150)
  createdAt  DateTime  @default(now()) @map("created_at")
  deletedAt  DateTime? @map("deleted_at")
  district   District  @relation(fields: [districtId], references: [id])

  @@unique([districtId, name])
  @@map("police_stations")
}

enum UserRole {
  developer
  state_admin
  district_admin
  naib_court
  viewer_district
  viewer_state
}

enum TransferEntityType {
  magistrate
  naib_court
}

enum GrievanceStatus {
  open
  in_progress
  escalated
  resolved
  cancelled
}

enum GrievanceLevel {
  district
  state
  developer
}

enum ColumnDataType {
  text
  number
  date
  year
  enum
  boolean
}

model SystemSetting {
  id    Int    @id @default(autoincrement())
  key   String @unique @db.VarChar(100)
  value String
  
  @@map("system_settings")
}

model DailySubmission {
  id          Int      @id @default(autoincrement())
  courtId     Int      @map("court_id")
  entryDate   DateTime @map("entry_date") @db.Date
  submittedAt DateTime @default(now()) @map("submitted_at")
  submittedBy Int      @map("submitted_by")

  court       Court    @relation(fields: [courtId], references: [id])
  user        User     @relation("SubmissionCreatedBy", fields: [submittedBy], references: [id])

  @@unique([courtId, entryDate])
  @@map("daily_submissions")
}
