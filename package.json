{
  "name": "court-portal-antigravity",
  "version": "1.0.0",
  "description": "Court Portal - Data Entry System for Naib Courts in Haryana",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "npm run dev --prefix client",
    "start": "NODE_ENV=production node server/index.js",
    "render:build": "cd client && npm install --include=dev && npm run build && cd .. && npx prisma generate && npx prisma migrate deploy && node prisma/seed-production.js",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "node prisma/seed-production.js",
    "db:studio": "npx prisma studio",
    "db:generate": "npx prisma generate",
    "db:sync": "node scripts/sync-ui-to-seed.js",
    "test": "jest"
  },
  "prisma": {
    "seed": "node prisma/seed-production.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "prisma": "^6.19.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "jest": "^30.2.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
